---
const dmg = "https://github.com/jnahian/reader.md/releases/latest/download/Reader.md.dmg";
const repo = "https://github.com/jnahian/reader.md";
---

<section class="relative overflow-hidden px-6 pb-16 pt-24 text-center">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <svg class="dot-grid absolute -left-8 -top-8 h-[calc(100%+4rem)] w-[calc(100%+4rem)] opacity-60">
      <defs>
        <pattern id="hero-dots" width="28" height="28" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1" style="fill: var(--border)" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-dots)" />
    </svg>

    <span class="glyph anim-a absolute left-[6%] top-[12%] font-mono text-4xl text-muted/12" style="animation-delay: -2s;">#</span>
    <span class="glyph anim-b absolute left-[14%] top-[64%] hidden font-mono text-2xl text-muted/10 sm:block" style="animation-delay: -6s;">##</span>
    <span class="glyph anim-c absolute left-[4%] top-[82%] font-mono text-xl text-muted/10" style="animation-delay: -3s;">- [ ]</span>
    <span class="glyph anim-a absolute left-[20%] top-[6%] hidden font-mono text-xl text-muted/8 sm:block" style="animation-delay: -9s;">[]( )</span>
    <span class="glyph anim-b absolute right-[6%] top-[16%] font-mono text-5xl text-muted/10" style="animation-delay: -4s;">&gt;</span>
    <span class="glyph anim-c absolute right-[16%] top-[6%] hidden font-mono text-2xl text-muted/10 sm:block" style="animation-delay: -1s;">$&hellip;$</span>
    <span class="glyph anim-a absolute right-[4%] top-[58%] font-mono text-2xl text-muted/10" style="animation-delay: -7s;">```</span>
    <span class="glyph anim-b absolute right-[10%] top-[84%] font-mono text-3xl text-muted/10" style="animation-delay: -5s;">~~</span>
    <span class="glyph anim-c absolute left-[10%] top-[40%] hidden font-mono text-xl text-muted/8 sm:block" style="animation-delay: -8s;">**</span>
    <span class="glyph anim-a absolute right-[3%] top-[38%] font-mono text-3xl text-accent/15" style="animation-delay: -10s;">*</span>
  </div>

  <div class="relative z-10">
    <img src="/icon.png" alt="Reader.md app icon" width="128" height="128" class="mx-auto" />
    <h1 class="mt-4 text-5xl font-bold tracking-tight">Reader.md</h1>
    <p class="mx-auto mt-3 max-w-xl text-xl text-muted">
      A fast, native markdown reader for your Mac. Point it at your notes, docs,
      or an entire repo — and just read.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href={dmg}
        class="rounded-full bg-accent px-6 py-3 font-medium text-accent-fg hover:opacity-90"
      >Download for Mac</a>
      <a
        href={repo}
        class="rounded-full border border-border px-6 py-3 font-medium hover:bg-bg-alt"
      >View on GitHub</a>
    </div>
    <p class="mt-4 text-sm text-muted">
      Free &amp; open source · macOS 13+ · Apple silicon · Auto-updates via Sparkle
    </p>
  </div>
</section>

<style>
  @keyframes dot-drift {
    from { transform: translate(0, 0); }
    to { transform: translate(-28px, -28px); }
  }
  .dot-grid {
    animation: dot-drift 70s linear infinite;
  }

  @keyframes float-a {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-14px) rotate(4deg); }
  }
  @keyframes float-b {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(12px) rotate(-3deg); }
  }
  @keyframes float-c {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-9px) rotate(-5deg); }
  }
  .glyph.anim-a { animation: float-a 14s ease-in-out infinite; }
  .glyph.anim-b { animation: float-b 17s ease-in-out infinite; }
  .glyph.anim-c { animation: float-c 11s ease-in-out infinite; }

  @media (prefers-reduced-motion: reduce) {
    .dot-grid,
    .glyph.anim-a,
    .glyph.anim-b,
    .glyph.anim-c {
      animation: none;
    }
  }
</style>
