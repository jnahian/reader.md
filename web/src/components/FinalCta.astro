---
import { releasesLatest } from "../data/site";
---

<section class="cta container reveal">
  <div class="cta__panel">
    <div class="cta__sweep" aria-hidden="true"></div>
    <h2 class="cta__title">Free, open source,<br />and unmistakably Mac.</h2>
    <p class="cta__sub">
      MIT-licensed. Requires macOS 13+. Liquid Glass lights up on macOS 26 (Tahoe).
    </p>
    <div class="cta__actions">
      <a href={releasesLatest} class="btn btn--light">Download the .dmg</a>
      <a href="/docs" class="btn btn--ghost">Read the docs</a>
    </div>
  </div>
</section>

<style>
  .cta {
    max-width: 1000px;
    padding-block: 40px 100px;
  }
  .cta__panel {
    position: relative;
    border-radius: 26px;
    overflow: hidden;
    padding: clamp(40px, 6vw, 72px);
    text-align: center;
    background: linear-gradient(150deg, oklch(0.72 0.16 260 / 0.22), oklch(0.72 0.16 205 / 0.14));
    border: 1px solid rgba(255, 255, 255, 0.14);
  }
  .cta__sweep {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 100px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    animation: sweep 7s ease-in-out 2s infinite;
    pointer-events: none;
  }
  .cta__title {
    margin: 0;
    font-size: clamp(30px, 4.4vw, 52px);
    line-height: 1.05;
  }
  .cta__sub {
    margin: 20px auto 34px;
    max-width: 46ch;
    font-size: 17px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.68);
  }
  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }
</style>
