---
// Fixed decorative gradient blobs behind all content.
// variant "home" floats/parallaxes two blobs; docs/changelog show one static.
import type { Page } from "../data/site";
interface Props {
  variant?: Page;
}
const { variant = "home" } = Astro.props;
---

{
  variant === "home" && (
    <div class="blobs" aria-hidden="true">
      <div class="blob blob--a" data-parallax="0.18" />
      <div class="blob blob--b" data-parallax="0.30" />
      <div class="blob blob--top" />
    </div>
  )
}
{variant === "docs" && <div class="blobs" aria-hidden="true"><div class="blob blob--docs" /></div>}
{
  variant === "changelog" && (
    <div class="blobs" aria-hidden="true">
      <div class="blob blob--changelog" />
    </div>
  )
}

<style>
  .blobs {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .blob {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
  }
  .blob--a {
    top: -160px;
    left: -120px;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle at 30% 30%, oklch(0.72 0.16 260 / 0.5), transparent 62%);
    filter: blur(30px);
    animation: floatY 11s ease-in-out infinite, hueDrift 18s ease-in-out infinite;
  }
  .blob--b {
    top: 38%;
    right: -160px;
    width: 560px;
    height: 560px;
    background: radial-gradient(circle at 60% 40%, oklch(0.72 0.16 205 / 0.42), transparent 64%);
    filter: blur(34px);
    animation: floatY 14s ease-in-out infinite reverse;
  }
  .blob--top {
    inset: 0;
    width: auto;
    height: auto;
    border-radius: 0;
    background: radial-gradient(120% 90% at 50% -10%, oklch(0.7 0.14 275 / 0.1), transparent 55%);
  }
  .blob--docs {
    top: -140px;
    right: -120px;
    width: 440px;
    height: 440px;
    background: radial-gradient(circle, oklch(0.72 0.16 260 / 0.28), transparent 66%);
    filter: blur(40px);
  }
  .blob--changelog {
    top: -140px;
    left: -120px;
    width: 440px;
    height: 440px;
    background: radial-gradient(circle, oklch(0.72 0.16 205 / 0.26), transparent 66%);
    filter: blur(40px);
  }
</style>
